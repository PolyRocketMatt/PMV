---
// Footer component
---

<footer class="footer">
	<div class="footer-top">
		<div class="container">
			<div class="footer-grid">
				<div class="footer-brand">
					<h3 class="footer-logo">
						<span class="praten">PRATEN</span>
						<span class="met">MET</span>
						<span class="verstraeten">VERSTRAETEN</span>
					</h3>
					<p class="footer-tagline">
						De talkshow die niemand verwachtte, maar iedereen nodig heeft.
					</p>
					<div class="social-links">
						<a href="#" class="social-link" aria-label="Instagram">
							<svg width="24" height="24" viewBox="0 0 24 24" fill="none">
								<rect x="2" y="2" width="20" height="20" rx="5" stroke="currentColor" stroke-width="2"/>
								<circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="2"/>
								<circle cx="18" cy="6" r="1" fill="currentColor"/>
							</svg>
						</a>
						<a href="#" class="social-link" aria-label="TikTok">
							<svg width="24" height="24" viewBox="0 0 24 24" fill="none">
								<path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5 20.1a6.34 6.34 0 0 0 10.86-4.43v-7a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-1-.1z" fill="currentColor"/>
							</svg>
						</a>
						<a href="#" class="social-link" aria-label="YouTube">
							<svg width="24" height="24" viewBox="0 0 24 24" fill="none">
								<path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.33z" fill="currentColor"/>
								<path d="M9.75 15.02l5.75-3.27-5.75-3.27v6.54z" fill="#0F172A"/>
							</svg>
						</a>
						<a href="#" class="social-link" aria-label="Twitter/X">
							<svg width="24" height="24" viewBox="0 0 24 24" fill="none">
								<path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" fill="currentColor"/>
							</svg>
						</a>
					</div>
				</div>

				<div class="footer-links">
					<h4 class="footer-title">Quick Links</h4>
					<ul class="link-list">
						<li><a href="#about">Over De Show</a></li>
						<li><a href="#team">Meet The Team</a></li>
						<li><a href="#guests">Upcoming Guests</a></li>
						<li><a href="#recording-dates">Studio Opnames</a></li>
					</ul>
				</div>

				<div class="footer-links">
					<h4 class="footer-title">Contact</h4>
					<ul class="link-list">
						<li><a href="#">Info & Vragen</a></li>
						<li><a href="#">Pers & Media</a></li>
						<li><a href="#">Word een Gast</a></li>
						<li><a href="#">Partnerships</a></li>
					</ul>
				</div>

				<div class="footer-newsletter">
					<h4 class="footer-title">Stay Updated</h4>
					<p class="newsletter-text">
						Mis geen enkel moment! Schrijf je in voor updates over nieuwe afleveringen en exclusieve content.
					</p>
					<form class="newsletter-form">
						<input
							type="email"
							placeholder="je@email.com"
							class="newsletter-input"
							required
						/>
						<button type="submit" class="newsletter-button">
							<svg width="20" height="20" viewBox="0 0 20 20" fill="none">
								<path d="M18 2L9 11M18 2L12 18L9 11M18 2L2 8L9 11" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
							</svg>
						</button>
					</form>
				</div>
			</div>
		</div>
	</div>

	<div class="footer-bottom">
		<div class="container">
			<div class="footer-bottom-content">
				<p class="copyright">
					© 2026 Praten Met Verstraeten. All rights reserved. Made with 🔥 by the team.
				</p>
				<div class="footer-legal">
					<a href="#">Privacy Policy</a>
					<span class="separator">•</span>
					<a href="#">Terms of Service</a>
					<span class="separator">•</span>
					<a href="#">Cookies</a>
				</div>
			</div>
		</div>
	</div>

	<!-- Easter egg -->
	<div class="easter-egg">
		<button class="easter-egg-button" id="ronzilla-button">
			🎤
		</button>
	</div>
</footer>

<script>
	document.addEventListener('DOMContentLoaded', () => {
		// Newsletter form handler
		const newsletterForm = document.querySelector('.newsletter-form');
		if (newsletterForm) {
			newsletterForm.addEventListener('submit', (e) => {
				e.preventDefault();

				// Show joke popup
				const message = document.createElement('div');
				message.className = 'newsletter-joke-message';
				message.innerHTML = `
					<div class="newsletter-joke-content">
						<h2>📧❌</h2>
						<p>Deze talkshow begrijpt dat je niet nóg meer nieuwsbrieven nodig hebt, en zal je mail adres dan ook niet opslaan!</p>
						<p>Toch bedankt voor het vertrouwen 😉</p>
						<button class="close-joke">Sluiten</button>
					</div>
				`;
				document.body.appendChild(message);

				setTimeout(() => {
					message.classList.add('show');
				}, 10);

				const closeBtn = message.querySelector('.close-joke');
				closeBtn?.addEventListener('click', () => {
					message.classList.remove('show');
					setTimeout(() => message.remove(), 300);
				});

				// Reset form
				(newsletterForm as HTMLFormElement).reset();
			});
		}

		// Easter egg - Ronzilla sound
		const ronzillaButton = document.getElementById('ronzilla-button');
		let clickCount = 0;

		if (ronzillaButton) {
			ronzillaButton.addEventListener('click', () => {
				clickCount++;

				if (clickCount === 1) {
					ronzillaButton.textContent = '🎵';
				} else if (clickCount === 2) {
					ronzillaButton.textContent = '🔊';
				} else if (clickCount >= 3) {
					// Show Ronzilla message
					const message = document.createElement('div');
					message.className = 'ronzilla-message';
					message.innerHTML = `
						<div class="ronzilla-content">
							<h2>RONZILLAAAA!</h2>
							<p>🎉 Je hebt de geheime Ronzilla button gevonden! 🎉</p>
							<button class="close-ronzilla">Sluiten</button>
						</div>
					`;
					document.body.appendChild(message);

					setTimeout(() => {
						message.classList.add('show');
					}, 10);

					const closeBtn = message.querySelector('.close-ronzilla');
					closeBtn?.addEventListener('click', () => {
						message.classList.remove('show');
						setTimeout(() => message.remove(), 300);
						clickCount = 0;
						ronzillaButton.textContent = '🎤';
					});
				}
			});
		}

		// Smooth scroll for anchor links (but not placeholder links)
		document.querySelectorAll('a[href^="#"]').forEach(anchor => {
			anchor.addEventListener('click', function (e) {
				const href = anchor.getAttribute('href');
				// Only handle actual section anchors, not placeholder "#" links
				if (href && href !== '#' && href.length > 1) {
					e.preventDefault();
					const target = document.querySelector(href);
					if (target) {
						target.scrollIntoView({
							behavior: 'smooth',
							block: 'start'
						});
					}
				}
			});
		});
	});
</script>

<style>
	.footer {
		background: linear-gradient(180deg, #0F172A 0%, #020617 100%);
		position: relative;
		overflow: hidden;
	}

	.footer-top {
		padding: 5rem 0 3rem;
		border-bottom: 1px solid rgba(255, 255, 255, 0.1);
	}

	.footer-grid {
		display: grid;
		grid-template-columns: 2fr 1fr 1fr 1.5fr;
		gap: 4rem;
	}

	.footer-brand {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.footer-logo {
		font-size: 2rem;
		line-height: 1.2;
		display: flex;
		flex-direction: column;
		gap: 0.1rem;
	}

	.footer-logo span {
		display: block;
		background: var(--color-gradient-3);
		background-clip: text;
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
	}

	.footer-logo .praten {
		font-size: 1em;
	}

	.footer-logo .met {
		font-size: 0.5em;
	}

	.footer-logo .verstraeten {
		font-size: 1em;
	}

	.footer-tagline {
		color: #94A3B8;
		font-size: 0.95rem;
		line-height: 1.6;
		max-width: 300px;
	}

	.social-links {
		display: flex;
		gap: 1rem;
	}

	.social-link {
		width: 44px;
		height: 44px;
		display: flex;
		align-items: center;
		justify-content: center;
		background: rgba(99, 102, 241, 0.1);
		border: 1px solid rgba(99, 102, 241, 0.3);
		border-radius: 12px;
		color: var(--color-light);
		transition: all 0.3s ease;
	}

	.social-link:hover {
		background: var(--color-secondary);
		border-color: var(--color-secondary);
		transform: translateY(-3px);
		box-shadow: 0 10px 20px rgba(99, 102, 241, 0.3);
	}

	.footer-title {
		font-size: 1.2rem;
		color: var(--color-light);
		margin-bottom: 1.5rem;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.link-list {
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.link-list a {
		color: #94A3B8;
		font-size: 0.95rem;
		transition: all 0.2s ease;
		display: inline-block;
	}

	.link-list a:hover {
		color: var(--color-primary);
		transform: translateX(5px);
	}

	.footer-newsletter {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.newsletter-text {
		color: var(--color-text-muted);
		font-size: 0.9rem;
		line-height: 1.6;
	}

	.newsletter-form {
		display: flex;
		gap: 0.75rem;
	}

	.newsletter-input {
		flex: 1;
		padding: 1rem 1.5rem;
		background: rgba(0, 240, 255, 0.05);
		border: 2px solid rgba(0, 240, 255, 0.2);
		border-radius: 16px;
		color: var(--color-light);
		font-size: 1rem;
		font-family: 'Space Grotesk', sans-serif;
		transition: all 0.3s ease;
		font-weight: 500;
	}

	.newsletter-input:focus {
		outline: none;
		border-color: var(--color-secondary);
		background: rgba(0, 240, 255, 0.1);
		box-shadow: 0 0 20px rgba(0, 240, 255, 0.3), 0 0 40px rgba(0, 240, 255, 0.15);
		transform: translateY(-2px);
	}

	.newsletter-input::placeholder {
		color: var(--color-text-muted);
		font-weight: 400;
	}

	.newsletter-button {
		width: 56px;
		height: 56px;
		background: var(--color-gradient-2);
		border: 2px solid var(--color-secondary);
		border-radius: 16px;
		color: white;
		cursor: pointer;
		transition: all 0.3s ease;
		display: flex;
		align-items: center;
		justify-content: center;
		position: relative;
		overflow: hidden;
	}

	.newsletter-button::before {
		content: '';
		position: absolute;
		top: 0;
		left: -100%;
		width: 100%;
		height: 100%;
		background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
		transition: left 0.5s;
	}

	.newsletter-button:hover::before {
		left: 100%;
	}

	.newsletter-button:hover {
		transform: translateY(-3px) scale(1.05);
		box-shadow: var(--shadow-neon-cyan);
		border-color: var(--color-secondary);
	}

	.newsletter-button:active {
		transform: translateY(-1px) scale(1.02);
	}

	.footer-bottom {
		padding: 2rem 0;
	}

	.footer-bottom-content {
		display: flex;
		justify-content: space-between;
		align-items: center;
		flex-wrap: wrap;
		gap: 1rem;
	}

	.copyright {
		color: #64748B;
		font-size: 0.9rem;
	}

	.footer-legal {
		display: flex;
		gap: 1rem;
		align-items: center;
		font-size: 0.9rem;
	}

	.footer-legal a {
		color: #94A3B8;
		transition: color 0.2s ease;
	}

	.footer-legal a:hover {
		color: var(--color-primary);
	}

	.separator {
		color: #475569;
	}

	/* Easter Egg */
	.easter-egg {
		position: fixed;
		bottom: 2rem;
		right: 2rem;
		z-index: 1000;
	}

	.easter-egg-button {
		width: 60px;
		height: 60px;
		background: var(--color-gradient-1);
		border: none;
		border-radius: 50%;
		font-size: 1.8rem;
		cursor: pointer;
		transition: all 0.3s ease;
		box-shadow: 0 10px 30px rgba(255, 51, 102, 0.4);
		animation: float-button 3s ease-in-out infinite;
	}

	@keyframes float-button {
		0%, 100% { transform: translateY(0); }
		50% { transform: translateY(-10px); }
	}

	.easter-egg-button:hover {
		transform: scale(1.1) rotate(15deg);
		box-shadow: 0 15px 40px rgba(255, 51, 102, 0.6);
	}

	:global(.ronzilla-message) {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background: rgba(0, 0, 0, 0.9);
		display: flex;
		align-items: center;
		justify-content: center;
		z-index: 10000;
		opacity: 0;
		transition: opacity 0.3s ease;
	}

	:global(.ronzilla-message.show) {
		opacity: 1;
	}

	:global(.ronzilla-content) {
		background: var(--color-gradient-1);
		padding: 3rem;
		border-radius: 30px;
		text-align: center;
		max-width: 500px;
		animation: bounceIn 0.5s ease;
	}

	@keyframes bounceIn {
		0% { transform: scale(0.5); }
		50% { transform: scale(1.1); }
		100% { transform: scale(1); }
	}

	:global(.ronzilla-content h2) {
		font-size: 3rem;
		color: white;
		margin-bottom: 1rem;
		text-transform: uppercase;
		animation: shake 0.5s ease infinite;
	}

	@keyframes shake {
		0%, 100% { transform: rotate(0deg); }
		25% { transform: rotate(-5deg); }
		75% { transform: rotate(5deg); }
	}

	:global(.ronzilla-content p) {
		color: white;
		font-size: 1.2rem;
		margin-bottom: 2rem;
	}

	:global(.close-ronzilla) {
		background: white;
		color: var(--color-primary);
		border: none;
		padding: 1rem 2rem;
		border-radius: 50px;
		font-weight: 700;
		font-size: 1rem;
		cursor: pointer;
		transition: all 0.3s ease;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	:global(.close-ronzilla:hover) {
		transform: scale(1.05);
	}

	/* Newsletter Joke Popup */
	:global(.newsletter-joke-message) {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background: rgba(0, 0, 0, 0.9);
		display: flex;
		align-items: center;
		justify-content: center;
		z-index: 10000;
		opacity: 0;
		transition: opacity 0.3s ease;
	}

	:global(.newsletter-joke-message.show) {
		opacity: 1;
	}

	:global(.newsletter-joke-content) {
		background: var(--color-gradient-2);
		padding: 3rem;
		border-radius: 30px;
		text-align: center;
		max-width: 500px;
		animation: bounceIn 0.5s ease;
		box-shadow: 0 20px 60px rgba(0, 240, 255, 0.4);
	}

	:global(.newsletter-joke-content h2) {
		font-size: 3rem;
		color: white;
		margin-bottom: 1.5rem;
		text-shadow: 0 0 20px rgba(0, 240, 255, 0.8);
	}

	:global(.newsletter-joke-content p) {
		color: white;
		font-size: 1.1rem;
		line-height: 1.6;
		margin-bottom: 1rem;
		text-shadow: 0 1px 3px rgba(0, 0, 0, 0.3);
	}

	:global(.close-joke) {
		background: white;
		color: var(--color-secondary);
		border: none;
		padding: 1rem 2rem;
		border-radius: 50px;
		font-weight: 700;
		font-size: 1rem;
		cursor: pointer;
		transition: all 0.3s ease;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		margin-top: 1rem;
	}

	:global(.close-joke:hover) {
		transform: scale(1.05);
		box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
	}

	@media (max-width: 1024px) {
		.footer-grid {
			grid-template-columns: 1fr 1fr;
			gap: 3rem;
		}

		.footer-brand {
			grid-column: 1 / -1;
		}
	}

	@media (max-width: 768px) {
		.footer-top {
			padding: 3rem 0 2rem;
		}

		.footer-grid {
			grid-template-columns: 1fr;
			gap: 2rem;
		}

		.footer-bottom-content {
			flex-direction: column;
			text-align: center;
		}

		.footer-legal {
			flex-wrap: wrap;
			justify-content: center;
		}

		.easter-egg {
			bottom: 1rem;
			right: 1rem;
		}

		.easter-egg-button {
			width: 50px;
			height: 50px;
			font-size: 1.5rem;
		}

		:global(.ronzilla-content) {
			margin: 1rem;
			padding: 2rem;
		}

		:global(.ronzilla-content h2) {
			font-size: 2rem;
		}

		:global(.newsletter-joke-content) {
			margin: 1rem;
			padding: 2rem;
		}

		:global(.newsletter-joke-content h2) {
			font-size: 2rem;
		}
	}
</style>

