---
// Meet the Team section with character cards
const teamMembers = [
	{
		name: "Viktor Verstraeten",
		role: "Gastheer & Showmaster",
		bio: "De man, de mythe, de legende. Viktor is het charismatische hart van de show. Met zijn scherpe wit en natuurlijke charme maakt hij van elk interview een onvergetelijke ervaring. Van serious tot absurd, Viktor kan het allemaal.",
		traits: ["Charismatisch", "Spontaan", "Onvoorspelbaar"],
		image: "viktor-verstraeten.jpg"
	},
	{
		name: "Clara Vyncke",
		role: "Showrunner",
		bio: "Clara houdt Viktor met beide voeten op de grond... of probeert dat althans. Als showrunner is ze degene die de touwtjes in handen heeft. Scherp, slim en altijd klaar met een perfecte comeback. Ze zorgt ervoor dat de chaos gecontroleerd blijft - of zo goed als.",
		traits: ["Scherp", "Intelligent", "In Control"],
		image: "clara-vyncke.jpg"
	},
	{
		name: "Producer Ronny",
		role: "Producer & Chaos Coördinator",
		nickname: "AKA RONZILLAAAA",
		bio: "Ronny is niet zomaar een producer. Hij is een fenomeen. Een kracht der natuur. Achter de schermen houdt hij alles onder controle, maar voor de camera is hij een walking meme. RONZILLAAAA!",
		traits: ["Energiek", "Memeable", "Legendarisch"],
		image: "producer-ronny.jpg"
	}
];
---

<section id="team" class="meet-team">
	<div class="container">
		<div class="section-header">
			<h2 class="section-title">Meet The Team</h2>
			<div class="title-underline"></div>
			<p class="section-subtitle">De mensen die televisiegeschiedenis schrijven</p>
		</div>

		<div class="team-grid">
			{teamMembers.map((member, index) => (
				<div class="team-card" data-index={index}>
					<div class="card-inner">
						<div class="card-front">
							<div class="member-image-wrapper">
								<img src={`/images/team/${member.image}`} alt={member.name} class="member-image" />
								<div class="image-overlay">
									<span class="view-more">Klik voor meer</span>
								</div>
							</div>
							<div class="member-info">
								<h3 class="member-name">{member.name}</h3>
								{member.nickname && (
									<div class="member-nickname">{member.nickname}</div>
								)}
								<p class="member-role">{member.role}</p>
								<div class="member-traits">
									{member.traits.map(trait => (
										<span class="trait-badge">{trait}</span>
									))}
								</div>
							</div>
						</div>
						<div class="card-back">
							<div class="back-content">
								<h3 class="member-name">{member.name}</h3>
								<p class="member-bio">{member.bio}</p>
								<button class="flip-back-btn">← Terug</button>
							</div>
						</div>
					</div>
				</div>
			))}
		</div>

		<div class="team-quote">
			<svg class="quote-icon" width="48" height="48" viewBox="0 0 48 48" fill="none">
				<path d="M10 24C10 19.6 12 16 16 13.6C18.4 12 21.2 11.2 24 11.2V6C14.8 6 6 12.8 6 24C6 29.6 9.6 34 15.2 36.4L18.4 30.4C14 28.8 10 27.2 10 24ZM32 24C32 19.6 34 16 38 13.6C40.4 12 43.2 11.2 46 11.2V6C36.8 6 28 12.8 28 24C28 29.6 31.6 34 37.2 36.4L40.4 30.4C36 28.8 32 27.2 32 24Z" fill="currentColor"/>
			</svg>
			<p class="quote-text">
				"Samen zijn we een mix van chaos, comedy en pure entertainment. En eerlijk? We zouden het niet anders willen."
			</p>
			<p class="quote-author">— Het Team</p>
		</div>
	</div>
</section>

<script>
	// Add flip functionality to cards
	document.addEventListener('DOMContentLoaded', () => {
		const cards = document.querySelectorAll('.team-card');

		cards.forEach(card => {
			const cardInner = card.querySelector('.card-inner');
			const flipBackBtn = card.querySelector('.flip-back-btn');

			card.addEventListener('click', (e) => {
				const target = e.target as HTMLElement;
				if (!target.classList.contains('flip-back-btn')) {
					cardInner?.classList.toggle('flipped');
				}
			});

			flipBackBtn?.addEventListener('click', (e) => {
				e.stopPropagation();
				cardInner?.classList.remove('flipped');
			});
		});

		// Stagger animation on scroll
		const observerOptions = {
			threshold: 0.1,
			rootMargin: '0px'
		};

		const observer = new IntersectionObserver((entries) => {
			entries.forEach(entry => {
				if (entry.isIntersecting) {
					entry.target.classList.add('visible');
				}
			});
		}, observerOptions);

		cards.forEach((card, index) => {
			(card as HTMLElement).style.animationDelay = `${index * 0.2}s`;
			observer.observe(card);
		});
	});
</script>

<style>
	.meet-team {
		padding: 8rem 0;
		background: linear-gradient(180deg, #1a0a2e 0%, #0A0E27 50%, #1a0a2e 100%);
		position: relative;
		overflow: hidden;
	}

	.meet-team::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		height: 2px;
		background: linear-gradient(90deg, transparent, var(--color-primary), var(--color-secondary), transparent);
		box-shadow: 0 0 20px rgba(255, 0, 85, 0.5);
	}

	.section-header {
		text-align: center;
		margin-bottom: 5rem;
		position: relative;
		z-index: 1;
	}

	.section-title {
		font-size: clamp(3rem, 6vw, 5rem);
		color: var(--color-light);
		margin-bottom: 1rem;
		text-transform: uppercase;
		font-weight: 900;
		letter-spacing: -0.02em;
	}

	.title-underline {
		width: 120px;
		height: 5px;
		background: var(--color-gradient-1);
		margin: 0 auto 2rem;
		border-radius: 3px;
		box-shadow: var(--shadow-neon-pink);
	}

	.section-subtitle {
		font-size: 1.2rem;
		color: var(--color-text-muted);
		font-style: italic;
	}

	.team-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 3rem;
		margin-bottom: 5rem;
		perspective: 2000px;
		position: relative;
		z-index: 1;
	}

	.team-card {
		opacity: 0;
		transform: translateY(30px);
		animation: fadeInUpCard 0.6s ease forwards;
		animation-play-state: paused;
	}

	.team-card.visible {
		animation-play-state: running;
	}

	@keyframes fadeInUpCard {
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.card-inner {
		position: relative;
		width: 100%;
		height: 650px;
		transition: transform 0.8s cubic-bezier(0.4, 0.2, 0.2, 1);
		transform-style: preserve-3d;
		cursor: pointer;
		/* Ensure card stays in position during rotation */
		transform-origin: center center;
	}

	.card-inner.flipped {
		transform: rotateY(180deg);
	}

	.card-front,
	.card-back {
		position: absolute;
		width: 100%;
		height: 100%;
		backface-visibility: hidden;
		-webkit-backface-visibility: hidden;
		border-radius: 24px;
		overflow: hidden;
		/* Lock the position */
		top: 0;
		left: 0;
	}

	.card-front {
		background: linear-gradient(135deg, rgba(255, 0, 85, 0.08) 0%, rgba(0, 240, 255, 0.08) 100%);
		border: 2px solid rgba(255, 255, 255, 0.1);
		display: flex;
		flex-direction: column;
		transition: border-color 0.4s ease, box-shadow 0.4s ease;
		position: relative;
	}

	.card-front::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background: linear-gradient(135deg, transparent 0%, rgba(0, 240, 255, 0.1) 100%);
		opacity: 0;
		transition: opacity 0.4s ease;
		pointer-events: none;
	}

	/* Only apply hover effects when NOT flipped */
	.card-inner:not(.flipped):hover .card-front {
		border-color: var(--color-secondary);
		box-shadow: var(--shadow-neon-cyan);
		transform: translateY(-8px);
	}

	.card-inner:not(.flipped) .card-front:hover::before {
		opacity: 1;
	}

	/* Remove any transform when flipped */
	.card-inner.flipped .card-front {
		transform: none;
	}

	.card-back {
		background: linear-gradient(135deg, #FF0055 0%, #A855F7 50%, #00F0FF 100%);
		transform: rotateY(180deg);
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 3rem;
		box-shadow: 0 20px 60px rgba(255, 0, 85, 0.4);
	}

	.member-image-wrapper {
		position: relative;
		width: 100%;
		height: 420px;
		overflow: hidden;
		background: linear-gradient(135deg, #1a0a2e 0%, #0A0E27 100%);
	}

	.member-image {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.5s ease;
	}

	.card-front:hover .member-image {
		transform: scale(1.08);
	}

	.image-overlay {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background: linear-gradient(to top, rgba(10, 14, 39, 0.95) 0%, transparent 60%);
		display: flex;
		align-items: flex-end;
		justify-content: center;
		padding: 1.5rem;
		opacity: 0;
		transition: opacity 0.4s ease;
	}

	.card-front:hover .image-overlay {
		opacity: 1;
	}

	.view-more {
		color: var(--color-secondary);
		font-weight: 700;
		text-transform: uppercase;
		font-size: 0.9rem;
		letter-spacing: 0.15em;
		text-shadow: 0 0 10px rgba(0, 240, 255, 0.8);
		animation: pulse 2s ease-in-out infinite;
	}

	.member-info {
		padding: 2rem;
		flex: 1;
		display: flex;
		flex-direction: column;
		justify-content: center;
		background: linear-gradient(to bottom, rgba(10, 14, 39, 0.8) 0%, rgba(10, 14, 39, 0.95) 100%);
	}

	.member-name {
		font-size: 2rem;
		margin-bottom: 0.5rem;
		color: var(--color-light);
		font-weight: 900;
		letter-spacing: -0.02em;
	}

	.member-nickname {
		font-size: 1rem;
		color: var(--color-accent);
		font-weight: 700;
		margin-bottom: 0.5rem;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		text-shadow: 0 0 10px rgba(255, 215, 0, 0.5);
	}

	.member-role {
		font-size: 1rem;
		color: var(--color-primary);
		margin-bottom: 1.5rem;
		font-weight: 600;
	}

	.member-traits {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.trait-badge {
		background: rgba(0, 240, 255, 0.15);
		border: 1px solid var(--color-secondary);
		padding: 0.4rem 0.9rem;
		border-radius: 20px;
		font-size: 0.85rem;
		color: var(--color-light);
		font-weight: 600;
		transition: all 0.3s ease;
	}

	.trait-badge:hover {
		background: rgba(0, 240, 255, 0.3);
		transform: translateY(-2px);
		box-shadow: 0 0 15px rgba(0, 240, 255, 0.5);
	}

	.back-content {
		text-align: center;
		position: relative;
		z-index: 1;
	}

	.back-content .member-name {
		margin-bottom: 2rem;
		font-size: 2.5rem;
		text-shadow: 0 2px 10px rgba(0, 0, 0, 0.3);
	}

	.member-bio {
		color: var(--color-light);
		line-height: 1.8;
		font-size: 1.05rem;
		margin-bottom: 2.5rem;
		text-shadow: 0 1px 3px rgba(0, 0, 0, 0.3);
	}

	.flip-back-btn {
		background: rgba(255, 255, 255, 0.95);
		border: none;
		color: var(--color-primary);
		padding: 1rem 2.5rem;
		border-radius: 50px;
		font-weight: 700;
		cursor: pointer;
		transition: all 0.3s ease;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		font-size: 0.9rem;
		box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
	}

	.flip-back-btn:hover {
		background: white;
		transform: scale(1.05);
		box-shadow: 0 6px 20px rgba(0, 0, 0, 0.3);
	}

	.team-quote {
		max-width: 900px;
		margin: 0 auto;
		text-align: center;
		padding: 3rem;
		background: rgba(255, 215, 0, 0.05);
		border-radius: 24px;
		border: 2px solid rgba(255, 215, 0, 0.2);
		position: relative;
		box-shadow: 0 10px 40px rgba(255, 215, 0, 0.1);
	}

	.quote-icon {
		color: var(--color-accent);
		opacity: 0.3;
		margin-bottom: 1rem;
	}

	.quote-text {
		font-size: 1.5rem;
		font-style: italic;
		color: var(--color-light);
		line-height: 1.7;
		margin-bottom: 1.5rem;
		font-weight: 500;
	}

	.quote-author {
		color: var(--color-accent);
		font-weight: 700;
		font-size: 1.1rem;
	}

	@media (max-width: 1024px) {
		.team-grid {
			grid-template-columns: 1fr;
			gap: 2.5rem;
			max-width: 500px;
			margin-left: auto;
			margin-right: auto;
		}

		.card-inner {
			height: 600px;
		}

		.member-image-wrapper {
			height: 380px;
		}
	}

	@media (max-width: 768px) {
		.meet-team {
			padding: 5rem 0;
		}

		.section-header {
			margin-bottom: 3rem;
		}

		.team-grid {
			margin-bottom: 3rem;
		}

		.card-inner {
			height: 550px;
		}

		.member-image-wrapper {
			height: 340px;
		}

		.team-quote {
			padding: 2rem;
		}

		.quote-text {
			font-size: 1.2rem;
		}

		.back-content {
			padding: 1rem;
		}

		.back-content .member-name {
			font-size: 2rem;
		}

		.member-bio {
			font-size: 1rem;
		}
	}
</style>

