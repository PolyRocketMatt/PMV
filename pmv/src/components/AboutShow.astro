---
// About the Show section
---

<section id="about" class="about-show">
	<div class="container">
		<div class="section-header">
			<h2 class="section-title">Over De Show</h2>
			<div class="title-underline"></div>
		</div>

		<div class="about-content">
			<div class="about-text">
				<h3 class="about-subtitle">Welkom bij het meest onvoorspelbare uur op televisie!</h3>
				<p>
					<strong>Praten Met Verstraeten</strong> is niet zomaar een talkshow. Het is een wilde rit door de wereld van entertainment,
					waar gastheer Viktor Verstraeten samen met zijn team elke aflevering opnieuw de grenzen van het genre opzoekt.
				</p>
				<p>
					Van hilarische interviews tot bizarre sketches, van onverwachte gasten tot spontane momenten die je nergens anders ziet.
					Dit is de talkshow die durft te dromen, te lachen en vooral: om zichzelf te lachen.
				</p>
				<p>
					Met de scherpe humor van Clara Vyncke, de chaotische energie van Producer Ronny (aka Ronzillaaaa), en de onnavolgbare
					charme van Viktor zelf, is elke opname gegarandeerd entertainment van de hoogste kwaliteit.
				</p>
			</div>

			<div class="about-features">
				<div class="feature-card">
					<div class="feature-icon">🎭</div>
					<h4>Live Entertainment</h4>
					<p>Wees erbij tijdens de opnames en ervaar de magie van televisie</p>
				</div>
				<div class="feature-card">
					<div class="feature-icon">🔥</div>
					<h4>Onverwachte Gasten</h4>
					<p>Van celebrities tot bizarre persoonlijkheden</p>
				</div>
				<div class="feature-card">
					<div class="feature-icon">💫</div>
					<h4>Improvisatie</h4>
					<p>Geen script, alleen pure spontaniteit</p>
				</div>
				<div class="feature-card">
					<div class="feature-icon">🎪</div>
					<h4>Chaos & Comedy</h4>
					<p>Waar alles kan en alles mag</p>
				</div>
			</div>
		</div>

		<div class="stats-row">
			<div class="stat-item">
				<div class="stat-number" data-target="10000">0</div>
				<div class="stat-label">Live Toeschouwers</div>
			</div>
			<div class="stat-item">
				<div class="stat-number" data-target="50">0</div>
				<div class="stat-label">Legendarische Gasten</div>
			</div>
			<div class="stat-item">
				<div class="stat-number" data-target="100">0</div>
				<div class="stat-label">Virale Momenten</div>
			</div>
			<div class="stat-item">
				<div class="stat-number" data-target="1">0</div>
				<div class="stat-label">Iconische Viktor</div>
			</div>
		</div>
	</div>
</section>

<script>
	// Animate numbers on scroll
	const observerOptions = {
		threshold: 0.5,
		rootMargin: '0px'
	};

	const animateCounter = (element: HTMLElement) => {
		const target = parseInt(element.getAttribute('data-target') || '0');
		const duration = 2000;
		const step = target / (duration / 16);
		let current = 0;

		const timer = setInterval(() => {
			current += step;
			if (current >= target) {
				element.textContent = target.toLocaleString('nl-NL');
				clearInterval(timer);
			} else {
				element.textContent = Math.floor(current).toLocaleString('nl-NL');
			}
		}, 16);
	};

	const observer = new IntersectionObserver((entries) => {
		entries.forEach(entry => {
			if (entry.isIntersecting) {
				const numbers = entry.target.querySelectorAll('.stat-number');
				numbers.forEach((num) => animateCounter(num as HTMLElement));
				observer.unobserve(entry.target);
			}
		});
	}, observerOptions);

	const statsRow = document.querySelector('.stats-row');
	if (statsRow) {
		observer.observe(statsRow);
	}
</script>

<style>
	.about-show {
		padding: 8rem 0;
		background: linear-gradient(180deg, #0A0E27 0%, #1a0a2e 50%, #0A0E27 100%);
		position: relative;
		overflow: hidden;
	}

	.about-show::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background:
			radial-gradient(circle at 20% 50%, rgba(255, 0, 85, 0.1) 0%, transparent 50%),
			radial-gradient(circle at 80% 50%, rgba(0, 240, 255, 0.1) 0%, transparent 50%);
		pointer-events: none;
	}

	.section-header {
		text-align: center;
		margin-bottom: 4rem;
		position: relative;
		z-index: 1;
	}

	.section-title {
		font-size: clamp(3rem, 6vw, 5rem);
		color: var(--color-light);
		margin-bottom: 1rem;
		text-transform: uppercase;
		font-weight: 900;
		letter-spacing: -0.02em;
	}

	.title-underline {
		width: 120px;
		height: 5px;
		background: var(--color-gradient-1);
		margin: 0 auto;
		border-radius: 3px;
		box-shadow: var(--shadow-neon-pink);
	}

	.about-content {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 4rem;
		margin-bottom: 6rem;
		align-items: start;
		position: relative;
		z-index: 1;
	}

	.about-text {
		font-size: 1.1rem;
		line-height: 1.8;
		color: var(--color-text-light);
	}

	.about-subtitle {
		font-size: 1.8rem;
		color: var(--color-secondary);
		margin-bottom: 1.5rem;
		font-family: 'Montserrat', sans-serif;
		font-weight: 700;
		text-shadow: 0 0 20px rgba(0, 240, 255, 0.5);
	}

	.about-text p {
		margin-bottom: 1.5rem;
	}

	.about-text strong {
		color: var(--color-primary);
		font-weight: 700;
	}

	.about-features {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1.5rem;
	}

	.feature-card {
		background: rgba(255, 255, 255, 0.03);
		border: 2px solid rgba(0, 240, 255, 0.2);
		border-radius: 20px;
		padding: 2rem;
		text-align: center;
		transition: all 0.4s ease;
		cursor: pointer;
		position: relative;
		overflow: hidden;
	}

	.feature-card::before {
		content: '';
		position: absolute;
		top: 0;
		left: -100%;
		width: 100%;
		height: 100%;
		background: linear-gradient(90deg, transparent, rgba(0, 240, 255, 0.1), transparent);
		transition: left 0.5s;
	}

	.feature-card:hover::before {
		left: 100%;
	}

	.feature-card:hover {
		transform: translateY(-8px) scale(1.02);
		background: rgba(0, 240, 255, 0.08);
		border-color: var(--color-secondary);
		box-shadow: var(--shadow-neon-cyan);
	}

	.feature-icon {
		font-size: 3rem;
		margin-bottom: 1rem;
		display: block;
		filter: drop-shadow(0 0 10px rgba(255, 215, 0, 0.5));
	}

	.feature-card h4 {
		font-size: 1.4rem;
		margin-bottom: 0.5rem;
		color: var(--color-light);
		font-weight: 800;
	}

	.feature-card p {
		color: var(--color-text-muted);
		font-size: 0.95rem;
	}

	.stats-row {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 2rem;
		padding: 3rem;
		background: rgba(255, 0, 85, 0.05);
		backdrop-filter: blur(10px);
		border-radius: 24px;
		border: 2px solid rgba(255, 0, 85, 0.3);
		box-shadow: 0 10px 40px rgba(255, 0, 85, 0.2);
		position: relative;
		z-index: 1;
	}

	.stat-item {
		text-align: center;
	}

	.stat-number {
		font-size: clamp(2.5rem, 5vw, 4rem);
		font-weight: 900;
		background: var(--color-gradient-1);
		background-clip: text;
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		font-family: 'Montserrat', sans-serif;
		line-height: 1;
		margin-bottom: 0.5rem;
	}

	.stat-label {
		font-size: 0.9rem;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: var(--color-gray);
		font-weight: 600;
	}

	@media (max-width: 1024px) {
		.about-content {
			grid-template-columns: 1fr;
			gap: 3rem;
		}

		.stats-row {
			grid-template-columns: repeat(2, 1fr);
			gap: 2rem;
		}
	}

	@media (max-width: 768px) {
		.about-show {
			padding: 5rem 0;
		}

		.about-features {
			grid-template-columns: 1fr;
		}

		.stats-row {
			grid-template-columns: 1fr;
			gap: 1.5rem;
			padding: 2rem;
		}
	}
</style>

