--- 
import LogoIcon from "../assets/logo.svg" 
import LeuvenBackground from "../assets/leuven_night.jpg" 
--- 

<div class="logo-div" style={`background-image: url(${LeuvenBackground.src})`}> 
    <img src={LogoIcon.src} alt="Logo" /> 
</div>

<style>
    /* Fill the viewport completely */
    .logo-div { 
        position: relative;
        display: flex;
        justify-content: center;
        align-items: center;

        width: 100%;
        height: 100vh;
        background-size: cover; 
        background-position: center;
    }

    /* Gradient overlay behind logo, but logo is above it */
    .logo-div::before {
        content: "";
        position: absolute;
        inset: 0;
        z-index: 0;

        background: linear-gradient(
            to bottom,
            rgba(0,0,0,0.1) 0%,           
            rgba(17,17,17,0) 10%,    
            rgba(17,17,17,0) 90%,  
            rgba(39, 70, 110, 1) 100%, 
            #27466E 100%          
        );
    }

    .logo-div img {
        position: relative;         /* above the overlay */
        z-index: 1;

        max-width: 75%;
        height: auto;

        filter:
            brightness(1.15)
            drop-shadow(0 0 30px rgba(255,255,255,0.9));
    }
</style>